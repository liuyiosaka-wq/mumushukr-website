# 通义千问 API Key
# 登录阿里云 DashScope 控制台获取：https://dashscope.console.aliyun.com/apiKey
QWEN_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase
# 登录 Supabase 控制台 → Project Settings → API 获取
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxx

# 服务器端口（本地开发用，Vercel 会自动忽略）
PORT=3000

# 空档同步 Webhook 验证 Token（自定义一个随机字符串）
# 服务端用来验证 POST /api/availability/sync 的请求
# GitHub Actions 跑 scripts/scrape.js 也读这个值（在仓库 Secrets 里再配一份）
SYNC_TOKEN=your-random-secret-string-here

# 仅 scripts/scrape.js 本地调试时需要：sync 接口完整 URL
# 生产环境通过 GitHub Actions Secrets 注入
# SYNC_URL=https://shukr.vercel.app/api/availability/sync
